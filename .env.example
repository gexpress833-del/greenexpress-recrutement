# En local : PORT=4050. Sur Render : PORT est défini automatiquement — ne pas le surcharger.
PORT=4050
#
# ——— Render (obligatoire sur le SERVICE WEB, pas seulement en local) ———
# Dashboard → votre Web Service (ex. greenexpress-recrutement) → Environment :
#   ajoutez la variable DATABASE_URL avec l’« Internal Database URL » de votre base Postgres
#   (bouton Link Database / copier depuis la base → Connect / Internal).
# Sans cette variable sur le service web, le formulaire renvoie « Impossible d’enregistrer la candidature ».
# Le fichier .env sur votre PC ne configure pas le déploiement Render.
#
# Connexion depuis votre machine (hôte externe) — remplacez MOT_DE_PASSE par le secret du tableau Render :
# DATABASE_URL=postgresql://admin_green:MOT_DE_PASSE@dpg-d7c01ipj2pic739ue5ng-a.oregon-postgres.render.com/green_db_g696
# En local avec Postgres installé, soit une URL complète :
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/green_db_g696
# soit les variables séparées (sans DATABASE_URL) :
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=admin_green
PGPASSWORD=votre_mot_de_passe
PGDATABASE=green_db_g696
JWT_SECRET=generez_une_chaine_longue_aleatoire_min_32_caracteres
ADMIN_EMAIL=votre@email.com
ADMIN_PASSWORD=votre_mot_de_passe_admin
